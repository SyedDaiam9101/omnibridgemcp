# ────────────── OMNIBRIDGE CONFIGURATION ──────────────
# 2026 AI Agent Execution Layer - Centralized Env vars

# 1. TRANSPORT SETTINGS
# Options: 'stdio' (for local IDEs) or 'http' (for cloud/remote)
MCP_TRANSPORT=stdio
PORT=3000

# 2. SECURITY & ATTESTATION
# HMAC-SHA256 Secret key for signing execution receipts.
# Keep this secure! In production, use at least 64 chars.
ATTESTATION_SECRET=dev-unsafe-default-secret-key-2026

# 3. SANDBOX CONSTRAINTS
# Comma-separated list of allowed Docker images
ALLOWED_IMAGES=node:20-slim,python:3.12-slim,rust:1.78-slim,alpine:latest

# Container Resource Limits
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1.0

# Docker socket override (useful on Windows/Docker Desktop):
# - Legacy: //./pipe/docker_engine
# - Desktop Linux engine: //./pipe/dockerDesktopLinuxEngine
DOCKER_SOCKET_PATH=

# 4. LIFECYCLE
DEFAULT_TTL_SECONDS=120
MAX_TTL_SECONDS=600
PROMETHEUS_METRICS_ENABLED=false

# 5. GOVERNANCE (HTTP ONLY)
# When MCP_TRANSPORT=http, /mcp requires a Bearer JWT and validates it against
# either a remote JWKS (recommended) or a local mock JWK (testing only).
#
# Required for JWT validation:
OAUTH_ISSUER=urn:omnibridge:test
OAUTH_AUDIENCE=urn:omnibridge:api
OAUTH_JWKS_URL=
#
# Testing-only: set to a JWK public key JSON string (ex: scripts/test-governance.cjs)
MOCK_JWK_PUB=
#
# Tenant policy map (JSON). Keys are OAuth client IDs.
# Example:
# TENANT_POLICIES={"DEFAULT":{"allowedImages":["node:20-slim","python:3.12-slim"],"maxTtl":300},"tenant1":{"allowedImages":["node:20-slim"],"maxTtl":300}}
TENANT_POLICIES=
