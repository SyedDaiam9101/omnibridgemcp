# ────────────── OMNIBRIDGE CONFIGURATION ──────────────
# 2026 AI Agent Execution Layer - Centralized Env vars

# 1. TRANSPORT SETTINGS
# Options: 'stdio' (for local IDEs) or 'http' (for cloud/remote)
MCP_TRANSPORT=stdio
PORT=3000

# 2. SECURITY & ATTESTATION
# HMAC-SHA256 Secret key for signing execution receipts.
# Keep this secure! In production, use at least 64 chars.
ATTESTATION_SECRET=dev-unsafe-default-secret-key-2026

# 3. SANDBOX CONSTRAINTS
# Comma-separated list of allowed Docker images
ALLOWED_IMAGES=node:20-slim,python:3.12-slim,rust:1.78-slim,alpine:latest

# Container Resource Limits
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1.0

# 4. LIFECYCLE
DEFAULT_TTL_SECONDS=120
MAX_TTL_SECONDS=600
PROMETHEUS_METRICS_ENABLED=false